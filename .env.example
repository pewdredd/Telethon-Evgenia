# Server
HOST=0.0.0.0
PORT=8000
API_KEY=change-me-to-a-secret-key

# Default rate limits (for new accounts)
MAX_MESSAGES_PER_DAY=25
MIN_DELAY_SECONDS=30
MAX_DELAY_SECONDS=90

# Database
DB_PATH=data/send_log.db

# Sessions directory
SESSIONS_DIR=data/sessions

